# =============================================================================
# openPic-mcp 配置文件
# =============================================================================
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env
#
# 配置优先级：.env 文件 > config 模块默认值
# =============================================================================

# -----------------------------------------------------------------------------
# API 配置（必填）
# -----------------------------------------------------------------------------

# Vision API 基础 URL
# 支持任何 OpenAI-Compatible 的 Vision API 服务
# 示例：
#   - OpenAI: https://api.openai.com/v1
#   - Azure OpenAI: https://your-resource.openai.azure.com/openai/deployments/your-deployment
#   - 自托管服务: https://your-server.com/v1
VISION_API_BASE_URL=https://api.openai.com/v1

# Vision API 密钥
# 请妥善保管，不要提交到版本控制系统
VISION_API_KEY=sk-your-api-key-here

# Vision 模型名称
# 常用模型：
#   - OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
#   - 其他兼容服务: 请参考对应服务的文档
VISION_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# 可选配置
# -----------------------------------------------------------------------------

# API 请求超时时间
# 默认值：30s
# 格式：Go duration 格式，如 30s（30秒）、2m（2分钟）、1m30s（1分30秒）
# 注意：必须带单位，纯数字如 "120" 会导致解析错误
# 对于大图片或复杂分析，建议适当增加此值
VISION_TIMEOUT=30s

