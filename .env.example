# =============================================================================
# openPic-mcp 配置文件
# =============================================================================
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env
#
# 配置优先级：OPENPIC_* > VISION_* > config 模块默认值
# =============================================================================

# -----------------------------------------------------------------------------
# API 配置（必填）
# -----------------------------------------------------------------------------

# OpenAI-Compatible 图像 API 基础 URL
# 支持视觉理解、图片比较、图片生成和图片编辑服务
# 示例：
#   - OpenAI: https://api.openai.com/v1
#   - Azure OpenAI: https://your-resource.openai.azure.com/openai/deployments/your-deployment
#   - 自托管服务: https://your-server.com/v1
OPENPIC_API_BASE_URL=https://api.openai.com/v1

# API 密钥
# 请妥善保管，不要提交到版本控制系统
OPENPIC_API_KEY=your-api-key-here

# 视觉理解模型名称（用于 describe_image / compare_images）
# 常用模型（截至 2026-04-29，以 OpenAI API 实际可用为准）：
#   - 旗舰：gpt-5.5（2026-04-23 发布，复杂推理/编码/研究 best-in-class）
#   - 高精度：gpt-5.5-pro
#   - 平衡型：gpt-5.4 / gpt-5.4-pro
#   - 轻量/高并发：gpt-5.4-mini（推荐默认轻量选项） / gpt-5.4-nano
#   - 旧版回退：gpt-5、gpt-5.2（仍可用作 snapshot，不推荐作默认）
#   - 其他兼容服务：请参考对应服务的文档
OPENPIC_VISION_MODEL=gpt-5.5

# 图片生成或编辑模型名称（仅在使用 generate_image / edit_image 时必填）
# 常用模型（截至 2026-04）：
#   - gpt-image-2（OpenAI 当前旗舰，2026-04-22 发布，原生 4K、思考模式、API 可用）
#   - gpt-image-1.5 / gpt-image-1（前代，仍可用，部分代理对其更宽松）
OPENPIC_IMAGE_MODEL=gpt-image-2

# -----------------------------------------------------------------------------
# 可选配置
# -----------------------------------------------------------------------------

# API 请求超时时间
# 默认值：5m
# 格式：Go duration 格式，如 30s（30秒）、2m（2分钟）、5m（5分钟）
# 注意：必须带单位，纯数字如 "120" 会导致解析错误
# gpt-image-2 等图片生成/编辑模型可能需要 1-4 分钟，建议不要低于 5m
OPENPIC_TIMEOUT=5m

# 日志级别
OPENPIC_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# 图片输出策略（仅作用于 generate_image / edit_image）
# -----------------------------------------------------------------------------

# 落盘目录（绝对路径），留空时使用 os.TempDir()/openpic-mcp/
# 单次 MCP 调用可通过工具参数 output_dir 覆盖此值
# OPENPIC_OUTPUT_DIR=/var/lib/openpic-mcp/images

# 文件名前缀（[A-Za-z0-9._-]，<=32 字符，不能以 . 开头）
# 留空时按工具上下文使用 generate / edit
# 单次调用可通过 filename_prefix 覆盖
# OPENPIC_FILENAME_PREFIX=demo

# 内联 base64 payload 字节上限。
# 默认 1048576（1 MiB），保护 MCP transcript 不被超大图撑爆。
# response_format=b64_json 且 payload 超阈：直接报错并提示改用 file_path。
# response_format=file_path 且 payload 超阈：照常落盘，但响应里追加 warning。
# 设置 0 / 负值会被忽略并回退到默认值，避免 misconfig 静默关闭 guard。
# OPENPIC_MAX_INLINE_PAYLOAD_BYTES=1048576

# 文件名冲突时是否覆盖。默认 false：在文件名后追加 -2 / -3 ... 直到唯一。
# true 时直接替换同名文件（仍受目录权限约束）。
# OPENPIC_OVERWRITE=false

# -----------------------------------------------------------------------------
# 服务器并发与生命周期（C4/C5 引入）
# -----------------------------------------------------------------------------
# 这一组配置覆盖 internal/server.Server 引擎：
# 收到 tools/call 走 worker pool，其它消息保持 recv loop 同步派发；
# 队列满时同步回退处理而不丢请求；
# 收到 SIGINT/SIGTERM 后等待 in-flight 排空，超过 ShutdownTimeout 强制取消。

# 同时执行的 tools/call 上限。
# 默认 16；硬上限 100；0 / 负值 / 解析失败时回退默认；超过上限自动 clamp。
# OPENPIC_MAX_CONCURRENT_REQUESTS=16

# tools/call 等待 worker 的有界队列长度。
# 默认 64；硬上限 10000；0 / 负值 / 解析失败时回退默认；超过上限自动 clamp。
# 队列满时由 recv loop 同步回退处理（绝不丢请求）。
# OPENPIC_REQUEST_QUEUE_SIZE=64

# 单个 tools/call 的最大执行时间（Go duration）。
# 默认 0s = 不设上限（图片生成可能需要 1-4 分钟）。
# 设置后超时会触发 ctx.Done，工具应在响应中带上 timeout 错误。
# OPENPIC_REQUEST_TIMEOUT=0s

# 优雅停机预算（Go duration）。
# 收到 SIGINT/SIGTERM 后引擎等待 in-flight tools/call 完成的最长时间，
# 超时后会强制 engineCancel 让 ctx-aware 工具立即返回。
# 默认 30s；必须 > 0。
# OPENPIC_SHUTDOWN_TIMEOUT=30s

# 日志格式：text 或 json。默认 text；其它值在 Load 路径直接报错。
# 所有日志一律写 stderr，stdout 仅承载 MCP JSON-RPC 帧。
# OPENPIC_LOG_FORMAT=text

# -----------------------------------------------------------------------------
# 异步任务层（submit_image_task / get_task_result / list_tasks / cancel_task）
# -----------------------------------------------------------------------------

# 总开关：是否启用异步任务工具集。
# false → 4 个异步工具不注册，且不构造 store/dispatcher（节省内存与文件句柄）。
# 默认 true；适用于希望保持纯同步行为（例如 CI 烟测）的部署。
# OPENPIC_TASK_STORE_ENABLED=true

# 是否把任务 manifest 落盘到 $OPENPIC_OUTPUT_DIR/tasks/。
# false → 纯内存模式，重启即丢；适用于无写盘权限的容器或 ephemeral 环境。
# true  → DiskStore，启动期 MkdirAll + 写探针，失败立即 fail-fast（fatal 日志含
#         "tasks directory" 字样），绝不静默 fallback。
# 默认 true。
# OPENPIC_TASK_DISK_PERSIST=true

# 队列容量上限：store 中处于 queued 状态的任务数。
# 满则 submit_image_task 返回 ErrQueueFull；硬上限 10000。
# 默认 256。
# OPENPIC_TASK_MAX_QUEUED=256

# 终态保留窗口：completed/failed/cancelled/abandoned 任务的最大保留数量。
# 超过时按 finished_at 升序淘汰最旧；硬上限 100000。
# get_task_result 在淘汰后会返回 ErrTaskNotFound，调用方应在终态后及时取结果。
# 默认 1024。
# OPENPIC_TASK_MAX_RETAINED=1024

# 终态保留时间（Go duration）。GC ticker 按此清理过期任务。
# 必须 > 0；非法/零/负值在 Load 路径直接报错。
# 默认 24h。
# OPENPIC_TASK_TTL=24h

# 兼容旧变量名：
# VISION_API_BASE_URL=https://api.openai.com/v1
# VISION_API_KEY=your-api-key-here
# VISION_MODEL=gpt-5.5
# VISION_TIMEOUT=5m
# VISION_LOG_LEVEL=info

